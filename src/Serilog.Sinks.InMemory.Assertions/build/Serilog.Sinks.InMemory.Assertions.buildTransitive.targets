<?xml version="1.0" encoding="utf-8"?>

<Project>
  <!--
    Expose the bundled abstractions assembly as compile reference when this package is consumed.
    Adapter DLLs are now bundled by the DragoAnt.Assertions package.
    Packed as buildTransitive/$(NuGetPackageIdPrefix).Serilog.Sinks.InMemory.Assertions.targets
  -->
  <ItemGroup>
    <Reference Include="$(MSBuildThisFileDirectory)..\lib\netstandard2.0\DragoAnt.Assertions.Serilog.Abstractions.dll" />
  </ItemGroup>
</Project>
