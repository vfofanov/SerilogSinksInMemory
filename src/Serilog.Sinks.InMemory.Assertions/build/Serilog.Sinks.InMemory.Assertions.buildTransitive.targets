<?xml version="1.0" encoding="utf-8"?>

<Project>
  <!--
    Expose the bundled abstractions assembly as compile reference when this package is consumed.
    Adapter DLLs are bundled by the DragoAnt.Assertions.Serilog package.
    Packed as buildTransitive/$(NuGetPackageIdPrefix).Serilog.Sinks.InMemory.Assertions.targets
  -->
  <ItemGroup>
    <Reference Include="DragoAnt.Assertions.Serilog.Abstractions">
      <HintPath>$(MSBuildThisFileDirectory)..\lib\netstandard2.0\DragoAnt.Assertions.Serilog.Abstractions.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>
</Project>
