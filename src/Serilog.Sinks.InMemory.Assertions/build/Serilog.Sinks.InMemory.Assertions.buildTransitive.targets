<?xml version="1.0" encoding="utf-8"?>

<Project>
  <!--
    NuGet only adds the assembly matching the package id as a compile reference.
    This package ships multiple assemblies under lib/netstandard2.0; expose them for compilation.
    Packed as buildTransitive/$(NuGetPackageIdPrefix).Serilog.Sinks.InMemory.Assertions.targets
  -->
  <ItemGroup>
    <Reference Include="$(MSBuildThisFileDirectory)..\lib\netstandard2.0\Serilog.Sinks.InMemory.Assertions.Abstractions.dll" />
    <Reference Include="$(MSBuildThisFileDirectory)..\lib\netstandard2.0\Serilog.Sinks.InMemory.FluentAssertions5.dll" />
    <Reference Include="$(MSBuildThisFileDirectory)..\lib\netstandard2.0\Serilog.Sinks.InMemory.FluentAssertions6.dll" />
    <Reference Include="$(MSBuildThisFileDirectory)..\lib\netstandard2.0\Serilog.Sinks.InMemory.FluentAssertions7.dll" />
    <Reference Include="$(MSBuildThisFileDirectory)..\lib\netstandard2.0\Serilog.Sinks.InMemory.FluentAssertions8.dll" />
    <Reference Include="$(MSBuildThisFileDirectory)..\lib\netstandard2.0\Serilog.Sinks.InMemory.AwesomeAssertions8.dll" />
    <Reference Include="$(MSBuildThisFileDirectory)..\lib\netstandard2.0\Serilog.Sinks.InMemory.AwesomeAssertions9.dll" />
    <Reference Include="$(MSBuildThisFileDirectory)..\lib\netstandard2.0\Serilog.Sinks.InMemory.Shouldly4.dll" />
  </ItemGroup>
</Project>