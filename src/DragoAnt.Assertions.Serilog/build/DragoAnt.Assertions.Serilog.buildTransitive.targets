<?xml version="1.0" encoding="utf-8"?>

<Project>
  <!--
    NuGet only adds the assembly matching the package id as a compile reference.
    This package ships multiple assemblies under lib/netstandard2.0; expose them for compilation.
  -->
  <ItemGroup>
    <Reference Include="DragoAnt.Assertions.Serilog.FluentAssertions5">
      <HintPath>$(MSBuildThisFileDirectory)..\lib\netstandard2.0\DragoAnt.Assertions.Serilog.FluentAssertions5.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="DragoAnt.Assertions.Serilog.FluentAssertions6">
      <HintPath>$(MSBuildThisFileDirectory)..\lib\netstandard2.0\DragoAnt.Assertions.Serilog.FluentAssertions6.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="DragoAnt.Assertions.Serilog.FluentAssertions7">
      <HintPath>$(MSBuildThisFileDirectory)..\lib\netstandard2.0\DragoAnt.Assertions.Serilog.FluentAssertions7.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="DragoAnt.Assertions.Serilog.FluentAssertions8">
      <HintPath>$(MSBuildThisFileDirectory)..\lib\netstandard2.0\DragoAnt.Assertions.Serilog.FluentAssertions8.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="DragoAnt.Assertions.Serilog.AwesomeAssertions8">
      <HintPath>$(MSBuildThisFileDirectory)..\lib\netstandard2.0\DragoAnt.Assertions.Serilog.AwesomeAssertions8.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="DragoAnt.Assertions.Serilog.AwesomeAssertions9">
      <HintPath>$(MSBuildThisFileDirectory)..\lib\netstandard2.0\DragoAnt.Assertions.Serilog.AwesomeAssertions9.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="DragoAnt.Assertions.Serilog.Shouldly4">
      <HintPath>$(MSBuildThisFileDirectory)..\lib\netstandard2.0\DragoAnt.Assertions.Serilog.Shouldly4.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>
</Project>
